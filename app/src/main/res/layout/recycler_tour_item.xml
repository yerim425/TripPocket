<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="8dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:rippleColor="@color/beige"
    app:cardElevation="8dp">

    <RelativeLayout
        android:id="@+id/layout_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_first_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:src="@drawable/test"
            android:background="#FFdddddd"/>

        <CheckBox
            android:id="@+id/cb_bookmark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            app:buttonCompat="@drawable/selector_bookmark"
            app:buttonTint="@null"
            android:scaleX="0.6"
            android:scaleY="0.6"
                android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:layout_below="@id/iv_first_image">
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="관광지 이름"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:lines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="#자연"
                android:textColor="@color/blue"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tv_addr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="관광지 주소"
                android:textSize="11sp"
                android:drawableStart="@drawable/baseline_location_on_24"
                android:drawablePadding="4dp"
                android:drawableTint="@color/icon_gray"
                android:maxLines="2"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/tv_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="행사기간"
                android:textSize="11sp"
                android:layout_marginTop="8dp"
                android:drawableStart="@drawable/outline_access_time_filled_24"
                android:drawableTint="@color/icon_gray"
                android:drawablePadding="4dp" />


        </LinearLayout>
    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>